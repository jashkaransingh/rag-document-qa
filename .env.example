# Anthropic API key, required for the default LLM backend
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional, override defaults
RAG_EMBEDDER=sentence-transformers  # or tfidf
RAG_LLM=anthropic                    # or stub
RAG_RETRIEVAL=mmr                    # or topk
RAG_K=5
RAG_AUTO_INGEST_DIR=                 # path to ingest at server startup
PORT=8000
